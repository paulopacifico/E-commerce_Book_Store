{
  "name": "bookstore-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "CI=1 ng build",
    "build:prod": "CI=1 ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "lint": "npm run lint:format && npm run typecheck",
    "lint:format": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.spec.json",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "check": "npm run lint && npm run test:ci && npm run build:prod",
    "theme:generate": "node tools/generate-tweakcn-theme.mjs"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@spartan-ng/brain": "^0.0.1-alpha.655",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lodash-es": "^4.17.23",
    "ngx-cookie-service": "^21.1.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@spartan-ng/cli": "^0.0.1-alpha.655",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
